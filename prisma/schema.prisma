// ============ LICENSE & CERTIFICATION ============

model License {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserLicense", fields: [userId], references: [id])
  licenseType     String   // LAWYER_LICENSE, SPECIALIZATION, CERTIFICATE, ACCREDITATION
  licenseNumber   String   @unique
  issuingBody     String?
  issueDate       String?
  expiryDate      String?
  status          String   @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED, PENDING_RENEWAL
