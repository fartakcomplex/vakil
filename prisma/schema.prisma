// ============ TENDERS & BIDS ============

model Tender {
  id              String   @id @default(cuid())
  title           String
  description     String?
  organization    String?
  tenderNumber    String?
  tenderType      String   @default("GOVERNMENT") // GOVERNMENT, PRIVATE, INTERNATIONAL
  budgetRange     String?  // JSON: {min, max}
  deadline        DateTime?
  status          String   @default("OPEN") // OPEN, CLOSED, AWARDED, CANCELLED
  requirements    String?  // JSON
  createdBy       String
  creator         User     @relation("TenderCreator", fields: [createdBy], references: [id])
  bids            TenderBid[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([tenderType])
  @@index([deadline])
}

model TenderBid {
  id          String   @id @default(cuid())
  tenderId    String
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  proposedBy  String
  proposer    User      @relation("BidProposer", fields: [proposedBy], references: [id])
  amount      Float?
  description String?
  status      String   @default("SUBMITTED") // SUBMITTED, SHORTLISTED, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenderId])
  @@index([proposedBy])
  @@index([status])
}

// ============ ELECTRONIC SIGNATURES ============

model SigningWorkflow {
  id          String   @id @default(cuid())
  title       String
  documentType String? // contract, letter, ruling, powerOfAttorney
  documentId  String?
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  createdBy   String
  creator     User     @relation("WorkflowCreator", fields: [createdBy], references: [id])
  signatures  ESignature[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([documentType])
}

model ESignature {
  id          String   @id @default(cuid())
  workflowId  String
  workflow    SigningWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  signerId    String
  signer      User     @relation("SignatureSigner", fields: [signerId], references: [id])
  order       Int      @default(0)
  status      String   @default("PENDING") // PENDING, SIGNED, REJECTED
  signedAt    DateTime?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([workflowId])
  @@index([signerId])
  @@index([status])
}

// ============ CASE EXECUTION MANAGEMENT ============

model CaseExecution {
  id              String   @id @default(cuid())
  caseId          String
  case            LegalCase @relation(fields: [caseId], references: [id])
  executionType   String   @default("JUDGMENT") // JUDGMENT, ATTACHMENT, FORFEITURE, EVICTION, SEIZURE
  status          String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SUSPENDED
  executionNumber String?
  court           String?
  judge           String?
  description     String?
  startDate       String?
  endDate         String?
  totalAmount     Float?
  collectedAmount Float    @default(0)
  actions         ExecutionAction[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([caseId])
  @@index([executionType])
  @@index([status])
}

model ExecutionAction {
  id          String   @id @default(cuid())
  executionId String
  execution   CaseExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  actionType  String   // filing, hearing, attachment, payment, notice
  title       String
  description String?
 actionDate  String?
  result      String?
  amount      Float?
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([executionId])
  @@index([actionDate])
}

// ============ PRO BONO LEGAL AID ============

model ProBonoCase {
  id              String   @id @default(cuid())
  title           String
  description     String?
  caseType        String?  // civil, criminal, family, labor
  applicantName   String
  applicantPhone  String?
  applicantEmail  String?
  incomeLevel     String?  // LOW, VERY_LOW
  status          String   @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, COMPLETED, REJECTED
  priority        String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignedTo      String?
  lawyer          User?    @relation("ProBonoLawyer", fields: [assignedTo], references: [id])
  notes           String?
  startDate       String?
  completedDate   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([caseType])
  @@index([assignedTo])
  @@index([priority])
}
